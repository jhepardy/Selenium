<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Sequential: stable with IRetryAnalyzer. For Grid parallelism use parallel-regression.xml or split suites. -->
<suite name="Smoke" parallel="none" verbose="1">
    <test name="internet-smoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automation.tests.internet.TheInternetLoginTest"/>
        </classes>
    </test>
</suite>
